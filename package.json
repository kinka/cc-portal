{
  "name": "claude-portal",
  "version": "0.1.0",
  "description": "HTTP service for remote Claude Code CLI control with persistent conversations",
  "license": "MIT",
  "type": "module",
  "keywords": [
    "claude",
    "claude-code",
    "anthropic",
    "agent",
    "http-api",
    "bun",
    "fastify"
  ],
  "scripts": {
    "start": "bun src/index.ts",
    "dev": "WECOM_DEBUG=1 bun --watch src/index.ts",
    "build": "bun build src/index.ts --outdir dist",
    "typecheck": "tsc --noEmit",
    "test": "bun test",
    "test:e2e": "RUN_E2E=1 bun test tests/e2e --timeout 120000"
  },
  "dependencies": {
    "@fastify/static": "^9.0.0",
    "@wecom/aibot-node-sdk": "^1.0.1",
    "fastify": "^5.8.2",
    "pino-pretty": "^13.1.3"
  },
  "devDependencies": {
    "@types/bun": "^1.3.10",
    "@types/node": "^20.19.37",
    "typescript": "^5.9.3"
  }
}