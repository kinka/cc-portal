{
  "name": "claude-portal",
  "version": "0.1.0",
  "description": "HTTP service for remote Claude Code CLI control with persistent conversations",
  "license": "MIT",
  "type": "module",
  "keywords": [
    "claude",
    "claude-code",
    "anthropic",
    "agent",
    "http-api",
    "bun",
    "fastify"
  ],
  "scripts": {
    "start": "bun src/index.ts",
    "dev": "bun --watch src/index.ts",
    "build": "bun build src/index.ts --outdir dist",
    "typecheck": "tsc --noEmit",
    "test": "bun test",
    "test:e2e": "RUN_E2E=1 bun test tests/e2e --timeout 120000"
  },
  "dependencies": {
    "@fastify/static": "^9.0.0",
    "fastify": "^5.2.0",
    "pino-pretty": "^13.1.3"
  },
  "devDependencies": {
    "@types/bun": "^1.1.14",
    "@types/node": "^20.12.3",
    "typescript": "^5.4.3"
  }
}
